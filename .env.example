# Gordon II — optional overrides (defaults live in app/config.py)
# Copy to .env only if you need local overrides; the app reads config.py directly today.

# Ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=nemotron3:33b
OLLAMA_EMBED_MODEL=nomic-embed-text

# GPU speech (Parakeet microservice on Spark)
NIM_ASR_URL=http://127.0.0.1:8010
NIM_ASR_MODEL=parakeet-tdt-0.6b-v3
ASR_BACKEND=auto

# Deploy (scripts/deploy_gx10.sh)
DEPLOY_HOST=asus@gx10-49d1
REMOTE_DIR=~/urban-ops-copilot
PORT=8080
# NVSYNC_KEY=$HOME/Library/Application Support/NVIDIA/Sync/config/nvsync.key

# NGC (only needed to build Parakeet ASR Docker image on Spark)
# NGC_API_KEY=
